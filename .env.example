# Database (Railway / Production)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Authentication (Backend)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-on-railway.app/auth/google/callback

# Frontend URL (For CORS and Auth Redirect)
FRONTEND_URL=https://your-frontend-on-vercel.app

# Google tokens (Optional, for scripts/dev)
GOOGLE_ACCESS_TOKEN=your_access_token_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Next.js Frontend (client/.env.local)
NEXT_PUBLIC_API_URL=https://your-backend-on-railway.app
